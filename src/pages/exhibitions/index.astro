---
import Layout from '../../layouts/Layout.astro';
import { exhibitions } from '../../data/exhibitions';
const base = import.meta.env.BASE_URL;

function coverUrl(e: typeof exhibitions[number]) {
  return `${base}exhibitions/${e.slug}/${e.coverSrc}`;
}
---
<Layout title="Exhibitions">

  <section class="section-sm page-header">
    <div class="container">
      <h1>Exhibitions</h1>
      <p>Artworks created through the Math + Code + Art initiative.</p>
    </div>
  </section>

  <section class="section" style="padding-top: 2rem; padding-bottom: 6rem">
    <div class="container">
      <div class="exh-list">
        {exhibitions.map(e => (
          <a href={`${base}exhibitions/${e.slug}`} class="exh-card card">
            <div class="exh-cover">
              <img src={coverUrl(e)} alt={e.title} loading="lazy" />
            </div>
            <div class="exh-body">
              <p class="exh-year">{e.year}</p>
              <h2 class="exh-title">{e.title}</h2>
              <p class="exh-subtitle">{e.subtitle}</p>
              <p class="exh-artists">{e.artists.join(', ')}</p>
            </div>
            <span class="exh-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
.page-header { border-bottom: 1px solid var(--border); padding-bottom: 2rem; }
.page-header h1 { margin-bottom: 0.4rem; }

.exh-list { display: flex; flex-direction: column; gap: 1rem; max-width: 760px; }

.exh-card {
  display: grid;
  grid-template-columns: 200px 1fr auto;
  align-items: stretch;
  gap: 0;
  padding: 0;
  overflow: hidden;
}

.exh-cover {
  overflow: hidden;
  flex-shrink: 0;
  min-height: 200px;
  position: relative;
}
.exh-cover img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease, opacity 0.2s ease;
}
.exh-card:hover .exh-cover img { transform: scale(1.05); opacity: 0.88; }

.exh-body {
  padding: 1.75rem 2rem;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}
.exh-year {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: var(--border);
  margin-bottom: 0.1rem;
}
.exh-title { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.1rem; }
.exh-subtitle { font-size: 0.88rem; color: var(--accent); font-weight: 500; }
.exh-artists { font-size: 0.8rem; color: var(--muted); margin-top: 0.25rem; }

.exh-arrow {
  color: var(--accent);
  font-size: 1.1rem;
  padding-right: 1.75rem;
  transition: transform 0.15s;
  flex-shrink: 0;
  display: flex;
  align-items: center;
}
.exh-card:hover .exh-arrow { transform: translateX(4px); }

@media (max-width: 560px) {
  .exh-card { grid-template-columns: 130px 1fr; }
  .exh-arrow { display: none; }
  .exh-body { padding: 1.25rem; }
}
</style>

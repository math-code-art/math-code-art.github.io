---
import Layout from '../layouts/Layout.astro';
import TutorialCard from '../components/TutorialCard.astro';
import { tutorials } from '../data/tutorials';
import { news } from '../data/news';
const base = import.meta.env.BASE_URL;
const latestNews = news.slice(0, 3);

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

const typeColors: Record<string, string> = {
  Talk: 'tag-talk', Exhibition: 'tag-exhibition',
  Publication: 'tag-publication', 'New Tutorial': 'tag-tutorial',
};
---
<Layout title="Home">

  <section class="hero">
    <div class="container">
      <p class="kicker">UCLA Mathematics</p>
      <h1>Math + Code + Art</h1>
      <p class="hero-desc">
        Nine tutorials connecting mathematical ideas to visual and audio output,
        each written as a Jupyter notebook with explanation and runnable code.
      </p>
      <div class="hero-btns">
        <a href={`${base}tutorials`} class="btn btn-primary">Browse tutorials</a>
        <a href={`${base}about`} class="btn btn-ghost">About</a>
      </div>
    </div>
  </section>

  {latestNews.length > 0 && (
    <section class="section news-strip" style="padding-top: 0; padding-bottom: 0">
      <div class="container">
        <div class="news-row">
          <span class="news-heading">Latest</span>
          {latestNews.map(item => (
            <a href={item.link ?? `${base}news`} class="news-pill" {...(item.link?.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
              <span class={`tag tag-sm ${typeColors[item.type] ?? ''}`}>{item.type}</span>
              <span class="news-pill-title">{item.title}</span>
              <span class="news-pill-date">{formatDate(item.date)}</span>
            </a>
          ))}
          <a href={`${base}news`} class="news-all">All news →</a>
        </div>
      </div>
    </section>
  )}

  <section class="section" style="padding-top: 0">
    <div class="container">
      <div class="grid-2">
        {tutorials.map((t, i) => (
          <TutorialCard
            tutorial={t}
            index={i}
            href={`${base}tutorials/${t.slug}`}
          />
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
/* News strip */
.news-strip { border-bottom: 1px solid var(--border); margin-bottom: 3.5rem; }
.news-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
  padding: 0.85rem 0;
}
.news-heading {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
  margin-right: 0.5rem;
  flex-shrink: 0;
}
.news-pill {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 99px;
  padding: 0.3rem 0.75rem 0.3rem 0.4rem;
  transition: border-color 0.15s;
}
.news-pill:hover { border-color: var(--accent); }
.tag-sm { font-size: 0.65rem; padding: 0.15rem 0.5rem; }
.news-pill-title { font-size: 0.8rem; color: var(--text); font-weight: 500; }
.news-pill-date  { font-size: 0.72rem; color: var(--muted); }
.news-all {
  font-size: 0.78rem;
  color: var(--muted);
  margin-left: auto;
  transition: color 0.15s;
  flex-shrink: 0;
}
.news-all:hover { color: var(--accent); }

.tag-talk        { background: rgba(167,139,250,0.12); color: #a78bfa; }
.tag-exhibition  { background: rgba(244,114,182,0.12); color: #f472b6; }
.tag-publication { background: rgba(52,211,153,0.12);  color: #34d399; }
.tag-tutorial    { background: rgba(251,191,36,0.12);  color: #fbbf24; }

/* Hero */
.hero {
  padding: 5rem 0 3.5rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: 3.5rem;
}
.kicker {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 1rem;
}
.hero h1 { margin-bottom: 1.1rem; }
.hero-desc {
  max-width: 520px;
  font-size: 1rem;
  line-height: 1.75;
  color: var(--muted);
}
.hero-btns {
  display: flex;
  gap: 0.75rem;
  margin-top: 2rem;
  flex-wrap: wrap;
}
</style>

---
import Layout from '../../layouts/Layout.astro';
import { tutorials } from '../../data/tutorials';

export function getStaticPaths() {
  return tutorials.map(t => ({ params: { slug: t.slug }, props: { tutorial: t } }));
}

const { tutorial: t } = Astro.props;
const base = import.meta.env.BASE_URL;

function resolveSrc(src: string): string {
  return src.startsWith('local:') ? `${base}gallery/${src.slice(6)}` : src;
}

const demoItems = t.gallery.map(g => ({ ...g, src: resolveSrc(g.src) }));
const dn = demoItems.length;
const allVideos = demoItems.every(i => i.kind === 'video');
const demoGrid = dn === 1 ? 'demo-1' : (allVideos || dn === 2) ? 'demo-2' : 'demo-3';
---
<Layout title={t.title} description={t.tagline}>

  <section class="section-sm page-header">
    <div class="container narrow">
      <a href={`${base}tutorials`} class="back">← Tutorials</a>
      <div class="tags">
        {t.tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
      <h1>{t.title}</h1>
      <p class="tagline">{t.tagline}</p>
    </div>
  </section>

  {demoItems.length > 0 && (
    <section class="section demos-section">
      <div class="container narrow">
        <div class={`demo-grid ${demoGrid}`}>
          {demoItems.map(item => (
            <div class="demo-item">
              {item.kind === 'video' ? (
                <div class="media-box video-box">
                  <video src={item.src} controls loop playsinline></video>
                </div>
              ) : (
                <div class="media-box img-box">
                  <img src={item.src} alt={item.caption ?? ''} loading="lazy" />
                </div>
              )}
              {item.caption && <p class="caption">{item.caption}</p>}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section" style="padding-top: 2rem">
    <div class="container narrow">

      <div class="content-grid">
        <div class="description">
          <p>{t.description}</p>
        </div>

        <aside class="sidebar">
          <div class="info-block">
            <p class="label">Concepts</p>
            <ul class="item-list">
              {t.concepts.map(c => <li>{c}</li>)}
            </ul>
          </div>

          <div class="info-block">
            <p class="label">Developed by</p>
            <ul class="item-list">
              {t.leads.map(l => <li>{l}</li>)}
            </ul>
          </div>

          {(t.githubUrl || t.notebooks.length > 0) && (
            <div class="info-block">
              <p class="label">Code</p>
              <div class="code-links">
                {t.githubUrl && (
                  <a href={t.githubUrl} target="_blank" rel="noopener noreferrer" class="nb-link">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                    View on GitHub
                  </a>
                )}
                {t.notebooks.map(nb => (
                  <a
                    href={nb.url.replace('https://github.com/', 'https://colab.research.google.com/github/')}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="colab-link"
                  >
                    <img src="https://colab.research.google.com/assets/colab-badge.svg" alt={`Open in Colab`} />
                    <span class="colab-label">{nb.label}</span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </aside>
      </div>

    </div>
  </section>

  {t.exhibitionSlug && (
    <section class="section exh-callout-section">
      <div class="container narrow">
        <a href={`${base}exhibitions/${t.exhibitionSlug}`} class="exh-callout">
          <div>
            <p class="exh-callout-label">Exhibition</p>
            <p class="exh-callout-title">Cellular Impressions</p>
            <p class="exh-callout-desc">Portraits Reimagined Through Algorithms</p>
          </div>
          <span class="exh-callout-arrow">→</span>
        </a>
      </div>
    </section>
  )}

  <!-- Lightbox -->
  <div id="lightbox" aria-hidden="true">
    <button id="lb-close" aria-label="Close">✕</button>
    <img id="lb-img" src="" alt="" />
  </div>

</Layout>

<style>
.narrow { max-width: 820px; }

/* Header */
.page-header { border-bottom: 1px solid var(--border); padding-bottom: 2rem; }
.back {
  display: inline-block;
  font-size: 0.82rem;
  color: var(--muted);
  margin-bottom: 1.25rem;
  transition: color 0.15s;
}
.back:hover { color: var(--text); }
.tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.85rem; }
h1 { margin-bottom: 0.5rem; }
.tagline {
  font-size: 0.95rem;
  color: var(--muted);
  font-weight: 500;
}

/* Video */
.video-wrap {
  position: relative;
  padding-bottom: 56.25%;
  height: 0;
  border-radius: var(--radius);
  overflow: hidden;
  border: 1px solid var(--border);
  margin-bottom: 2.5rem;
}
.video-wrap iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

/* Body layout */
.content-grid {
  display: grid;
  grid-template-columns: 1fr 260px;
  gap: 3rem;
  align-items: start;
}
@media (max-width: 680px) {
  .content-grid { grid-template-columns: 1fr; }
}

.description p {
  font-size: 0.97rem;
  color: var(--text);
  line-height: 1.8;
}

/* Sidebar */
.sidebar { display: flex; flex-direction: column; gap: 1.25rem; }
.info-block {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.1rem 1.25rem;
}
.label {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 0.65rem;
}
.item-list { display: flex; flex-direction: column; gap: 0.4rem; }
.item-list li {
  font-size: 0.85rem;
  color: var(--text);
  padding-left: 0.9rem;
  position: relative;
  line-height: 1.5;
}
.item-list li::before {
  content: '·';
  position: absolute;
  left: 0;
  color: var(--accent);
}
.nb-link {
  display: flex;
  align-items: center;
  gap: 0.45rem;
  font-size: 0.82rem;
  color: var(--accent);
  transition: opacity 0.15s;
  word-break: break-all;
}
.nb-link:hover { opacity: 0.75; }
.nb-link svg { flex-shrink: 0; }
.code-links { display: flex; flex-direction: column; gap: 0.6rem; }
.colab-link {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  transition: opacity 0.15s;
}
.colab-link:hover { opacity: 0.8; }
.colab-link img { height: 20px; display: block; flex-shrink: 0; }
.colab-label {
  font-size: 0.78rem;
  color: var(--muted);
  word-break: break-all;
}

/* Exhibition callout */
.exh-callout-section { padding-top: 0; padding-bottom: 0; border-top: 1px solid var(--border); }
.exh-callout {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.4rem 1.75rem;
  transition: border-color 0.15s;
}
.exh-callout:hover { border-color: var(--accent); }
.exh-callout-label {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 0.35rem;
}
.exh-callout-title { font-size: 1rem; font-weight: 600; color: var(--text); margin-bottom: 0.2rem; }
.exh-callout-desc { font-size: 0.82rem; color: var(--muted); }
.exh-callout-arrow { font-size: 1.2rem; color: var(--accent); transition: transform 0.15s; flex-shrink: 0; }
.exh-callout:hover .exh-callout-arrow { transform: translateX(4px); }

/* Demos */
.demos-section {
  padding-top: 2rem;
  padding-bottom: 0;
}
.demo-grid { display: grid; gap: 0.875rem; }
.demo-1 { grid-template-columns: 1fr; max-width: 740px; }
.demo-2 { grid-template-columns: repeat(2, 1fr); }
.demo-3 { grid-template-columns: repeat(3, 1fr); }

@media (max-width: 600px) {
  .demo-2, .demo-3 { grid-template-columns: 1fr; }
}

.media-box {
  border-radius: var(--radius);
  overflow: hidden;
  border: 1px solid var(--border);
  background: var(--surface);
}
.video-box { aspect-ratio: 16 / 9; background: #000; }
.video-box video { width: 100%; height: 100%; display: block; object-fit: contain; }
.img-box { aspect-ratio: 4 / 3; cursor: zoom-in; }
.img-box img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: transform 0.35s ease, opacity 0.2s ease;
}
.demo-item:hover .img-box img { transform: scale(1.04); opacity: 0.92; }
.caption {
  font-size: 0.75rem;
  color: var(--muted);
  margin-top: 0.4rem;
  line-height: 1.4;
}

/* Lightbox */
#lightbox {
  position: fixed;
  inset: 0;
  z-index: 1000;
  background: rgba(0, 0, 0, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease;
}
#lightbox.open { opacity: 1; pointer-events: all; }
#lb-img {
  max-width: 100%;
  max-height: 90vh;
  object-fit: contain;
  border-radius: var(--radius);
  box-shadow: 0 8px 60px rgba(0,0,0,0.6);
  transform: scale(0.96);
  transition: transform 0.2s ease;
}
#lightbox.open #lb-img { transform: scale(1); }
#lb-close {
  position: absolute;
  top: 1.25rem;
  right: 1.5rem;
  background: none;
  border: none;
  color: var(--muted);
  font-size: 1.4rem;
  cursor: pointer;
  line-height: 1;
  transition: color 0.15s;
}
#lb-close:hover { color: var(--text); }
</style>

<script>
const lb    = document.getElementById('lightbox')!;
const lbImg = document.getElementById('lb-img') as HTMLImageElement;

function openLightbox(src: string, alt: string) {
  lbImg.src = src;
  lbImg.alt = alt;
  lb.classList.add('open');
  lb.setAttribute('aria-hidden', 'false');
  document.body.style.overflow = 'hidden';
}
function closeLightbox() {
  lb.classList.remove('open');
  lb.setAttribute('aria-hidden', 'true');
  document.body.style.overflow = '';
}

document.querySelectorAll<HTMLElement>('.img-box').forEach(box => {
  box.addEventListener('click', () => {
    const img = box.querySelector('img')!;
    openLightbox(img.src, img.alt);
  });
});

document.getElementById('lb-close')!.addEventListener('click', closeLightbox);
lb.addEventListener('click', e => { if (e.target === lb) closeLightbox(); });
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });
</script>
